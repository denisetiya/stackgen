---
import Layout from '../layouts/Layout.astro';
import { GATEWAY_TYPES } from '@stackgen/core/schemas';

const gateways = JSON.stringify(GATEWAY_TYPES);
---
<Layout title="Gateway Generator — Stackgen">
  <div x-data="gatewayWizard" x-cloak>
    <div class="mb-6 flex flex-col gap-4 sm:mb-8 md:flex-row md:items-center md:justify-between">
      <div>
        <a href="/" class="inline-flex items-center gap-1.5 text-xs text-ink-400 hover:text-ink-200 transition">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back
        </a>
        <h1 class="mt-2 text-xl font-semibold tracking-tight sm:text-2xl">Gateway Generator</h1>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1.5">
          <template x-for="(s, i) in steps" :key="i">
            <div :class="{
              'bg-violet-500 shadow-[0_0_16px_rgba(167,139,250,0.7)]': step > i,
              'bg-violet-400 w-12 sm:w-14 shadow-[0_0_20px_rgba(167,139,250,0.9)]': step === i,
              'bg-ink-800': step < i
            }" class="h-1.5 w-8 rounded-full transition-all duration-300 sm:w-10"></div>
          </template>
        </div>
        <div class="font-mono text-xs text-ink-500 tabular-nums">
          <span x-text="String(step + 1).padStart(2,'0')"></span>
          <span class="text-ink-700">/</span>
          <span x-text="String(steps.length).padStart(2,'0')"></span>
        </div>
      </div>
    </div>

    <!-- STEP 0: Type -->
    <div x-show="step === 0" class="card-ambient p-4 sm:p-6" x-transition.opacity>
      <div class="mb-5 flex items-baseline justify-between gap-3 sm:mb-6">
        <div class="min-w-0">
          <h2 class="text-lg font-semibold tracking-tight sm:text-xl">Choose gateway type</h2>
          <p class="mt-1 text-xs text-ink-400 sm:text-sm">Routes between your microservices</p>
        </div>
        <span class="shrink-0 font-mono text-xs text-ink-600">01</span>
      </div>
      <div class="grid gap-2 sm:gap-3 md:grid-cols-2">
        <template x-for="gw in gateways" :key="gw.id">
          <button @click="config.type = gw.id" :class="config.type === gw.id ? 'border-violet-500/70 bg-violet-500/10 ring-1 ring-violet-500/30' : 'border-ink-800 hover:border-ink-700'" class="rounded-lg border bg-ink-900/40 p-3 text-left transition sm:p-4">
            <div class="text-sm font-semibold sm:text-base" x-text="gw.name"></div>
            <div class="mt-1 text-xs text-ink-400" x-text="gw.desc"></div>
            <div class="mt-3 font-mono text-[10px] text-ink-600">default port <span x-text="gw.defaultPort"></span></div>
          </button>
        </template>
      </div>
    </div>

    <!-- STEP 1: Services -->
    <div x-show="step === 1" class="card-ambient p-4 sm:p-6" x-transition.opacity>
      <div class="mb-5 flex items-baseline justify-between gap-3 sm:mb-6">
        <div class="min-w-0">
          <h2 class="text-lg font-semibold tracking-tight sm:text-xl">Backend services</h2>
          <p class="mt-1 text-xs text-ink-400 sm:text-sm">Each service routes to an upstream</p>
        </div>
        <span class="shrink-0 font-mono text-xs text-ink-600">02</span>
      </div>

      <template x-for="(svc, i) in config.services" :key="i">
        <div class="mb-4 rounded-lg border border-ink-800 bg-ink-950/40 p-3 sm:mb-5 sm:p-4">
          <div class="mb-3 flex items-center justify-between">
            <span class="font-mono text-xs text-ink-500">svc-<span x-text="i + 1"></span></span>
            <button @click="config.services.splice(i, 1)" x-show="config.services.length > 1" class="text-xs text-ink-500 hover:text-red-400 transition">Remove</button>
          </div>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
            <div>
              <label class="label">Name</label>
              <input type="text" class="input" x-model="svc.name" placeholder="api" />
            </div>
            <div>
              <label class="label">Upstream</label>
              <input type="text" class="input font-mono text-xs" x-model="svc.upstream" placeholder="api:3000" />
            </div>
            <div>
              <label class="label">Path</label>
              <input type="text" class="input font-mono text-xs" x-model="svc.path" placeholder="/api" />
            </div>
            <div>
              <label class="label">Domain</label>
              <input type="text" class="input font-mono text-xs" x-model="svc.domain" placeholder="api.example.com" />
            </div>
          </div>
          <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <div>
              <label class="label">Auth</label>
              <select class="input" x-model="svc.auth">
                <option value="none">None</option>
                <option value="jwt">JWT</option>
                <option value="keycloak">Keycloak</option>
              </select>
            </div>
            <div>
              <label class="label">Rate limit (rps)</label>
              <input type="number" class="input" x-model.number="svc.rateLimit" min="0" placeholder="0 = off" />
            </div>
            <div>
              <label class="label">CORS origins</label>
              <input type="text" class="input font-mono text-xs" :value="svc.corsOrigins.join(', ')" @input="svc.corsOrigins = $event.target.value.split(',').map(s => s.trim()).filter(Boolean)" placeholder="https://app.com" />
            </div>
          </div>
        </div>
      </template>
      <button @click="addService()" class="btn btn-ghost w-full">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Add service
      </button>
    </div>

    <!-- STEP 2: TLS -->
    <div x-show="step === 2" class="card-ambient p-4 sm:p-6" x-transition.opacity>
      <div class="mb-5 flex items-baseline justify-between gap-3 sm:mb-6">
        <div class="min-w-0">
          <h2 class="text-lg font-semibold tracking-tight sm:text-xl">TLS &amp; Dashboard</h2>
          <p class="mt-1 text-xs text-ink-400 sm:text-sm">HTTPS termination &amp; admin UI</p>
        </div>
        <span class="shrink-0 font-mono text-xs text-ink-600">03</span>
      </div>
      <div class="grid gap-4 sm:gap-5 md:grid-cols-2">
        <div>
          <label class="label">TLS mode</label>
          <select class="input" x-model="config.tls">
            <option value="none">None · HTTP only</option>
            <option value="selfsigned">Self-signed · dev/staging</option>
            <option value="letsencrypt">Let's Encrypt · prod</option>
          </select>
        </div>
        <div x-show="config.tls === 'letsencrypt'">
          <label class="label">Email (Let's Encrypt)</label>
          <input type="email" class="input" x-model="config.email" placeholder="you@example.com" />
        </div>
        <div class="md:col-span-2">
          <label class="flex cursor-pointer items-start gap-2.5 rounded-md border border-ink-800 bg-ink-950/40 p-3 hover:bg-ink-900/60 transition sm:items-center">
            <input type="checkbox" x-model="config.dashboard" class="mt-0.5 rounded border-ink-700 bg-ink-950 text-violet-600 focus:ring-violet-500 sm:mt-0" />
            <div>
              <div class="text-sm font-medium">Enable admin dashboard</div>
              <div class="text-xs text-ink-500">Kong Manager, Traefik dashboard, etc.</div>
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- STEP 3: Preview -->
    <div x-show="step === 3" class="card-ambient p-4 sm:p-6" x-transition.opacity>
      <div class="mb-5 flex items-baseline justify-between gap-3 sm:mb-6">
        <div class="min-w-0">
          <h2 class="text-lg font-semibold tracking-tight sm:text-xl">Preview &amp; Download</h2>
          <p class="mt-1 text-xs text-ink-400 sm:text-sm">Live preview of generated files</p>
        </div>
        <span class="shrink-0 font-mono text-xs text-ink-600">04</span>
      </div>
      <div class="grid gap-4 lg:grid-cols-[260px_1fr] lg:gap-5">
        <div>
          <h3 class="label">Files</h3>
          <div class="max-h-[300px] space-y-1 overflow-y-auto pr-2 sm:max-h-[500px]">
            <template x-for="(f, i) in files" :key="i">
              <button @click="active = i" :class="active === i ? 'bg-violet-500/15 text-violet-200 ring-1 ring-violet-500/30' : 'text-ink-400 hover:bg-ink-900/60 hover:text-ink-200'" class="w-full truncate rounded-md px-3 py-2 text-left font-mono text-xs transition" x-text="f.path"></button>
            </template>
          </div>
        </div>
        <div>
          <div class="mb-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <h3 class="truncate font-mono text-xs text-ink-300" x-text="files[active]?.path"></h3>
            <button @click="downloadZip()" class="btn btn-primary w-full text-xs sm:w-auto" :disabled="loading">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>
              <span x-show="!loading">Download ZIP</span>
              <span x-show="loading">Generating…</span>
            </button>
          </div>
          <pre class="overflow-auto rounded-lg border border-ink-800 bg-ink-950/80 p-3 text-xs leading-relaxed max-h-[400px] sm:max-h-[500px] sm:p-4"><code x-text="files[active]?.content"></code></pre>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="mt-5 flex flex-col-reverse gap-2 sm:mt-6 sm:flex-row sm:items-center sm:justify-between sm:gap-3">
      <button @click="prev()" :disabled="step === 0" class="btn btn-ghost w-full sm:w-auto">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Previous
      </button>
      <button @click="next()" :disabled="loading" class="btn btn-primary w-full sm:w-auto">
        <span x-show="step < steps.length - 1">Next step</span>
        <span x-show="step === steps.length - 1">Generate</span>
        <svg x-show="step < steps.length - 1" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>

    <div x-show="error" x-text="error" class="mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-300"></div>
  </div>

  <script is:inline define:vars={{ gateways }}>
    window.gatewayWizardData = { gateways: JSON.parse(gateways) };
  </script>

  <script>
    import { startAlpine } from '../lib/alpine';
    import { gatewayWizardFactory } from '../lib/wizards/gateway';

    startAlpine({ gatewayWizard: gatewayWizardFactory });
  </script>
</Layout>
