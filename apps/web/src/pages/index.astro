---
import Layout from '../layouts/Layout.astro';

const generators = [
  {
    href: '/docker',
    title: 'Docker',
    desc: 'Multi-service compose, build contexts, healthchecks, registries.',
    icon: 'docker',
  },
  {
    href: '/gateway',
    title: 'Gateway',
    desc: 'Kong, Envoy, NGINX, Traefik — auth, rate limits, routing.',
    icon: 'gateway',
  },
  {
    href: '/cicd',
    title: 'CI/CD',
    desc: 'GitHub Actions, GitLab CI, build · push · deploy pipelines.',
    icon: 'cicd',
  },
];
---

<Layout title="Stackgen — Generate Docker, Gateway & CI/CD">
  <!-- Hero -->
  <section class="section-ambient relative pt-8 pb-16 md:pt-14 md:pb-24">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-4 inline-flex items-center gap-1.5 chip">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.8)]"></span>
        self-hosted · open source
      </div>
      <h1 class="text-balance text-4xl font-semibold tracking-tight text-ink-50 sm:text-5xl md:text-6xl">
        Production scaffolding,
        <span class="bg-gradient-to-r from-violet-300 to-violet-500 bg-clip-text text-transparent">not starter templates</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-balance text-base text-ink-400 md:text-lg">
        Generate Docker compose, API gateways, and CI/CD pipelines as ZIP — with the configuration you'd actually ship.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-2">
        <a href="/docker" class="btn btn-primary">
          Start with Docker
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3.5 8h9m0 0L8.5 4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#generators" class="btn btn-ghost">View all generators</a>
      </div>
    </div>
  </section>

  <!-- Generator cards -->
  <section id="generators" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {generators.map((g) => (
      <a href={g.href} class="card-hover group block">
        <div class="flex items-start justify-between">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-ink-800 bg-ink-950/60 text-violet-300 transition group-hover:border-violet-500/40 group-hover:text-violet-200">
            {g.icon === 'docker' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="11" width="3" height="2" rx="0.5"/>
                <rect x="7" y="11" width="3" height="2" rx="0.5"/>
                <rect x="11" y="11" width="3" height="2" rx="0.5"/>
                <rect x="15" y="11" width="3" height="2" rx="0.5"/>
                <rect x="5" y="7" width="3" height="2" rx="0.5"/>
                <rect x="9" y="7" width="3" height="2" rx="0.5"/>
                <rect x="13" y="7" width="3" height="2" rx="0.5"/>
                <rect x="9" y="3" width="3" height="2" rx="0.5"/>
                <path d="M2 14c1.5 1 3 1.5 5 1.5h10c2 0 3.5-.5 5-1.5" stroke-linecap="round"/>
              </svg>
            )}
            {g.icon === 'gateway' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.5">
                <path d="M4 12h6m4 0h6M12 4v4m0 8v4" stroke-linecap="round"/>
                <circle cx="12" cy="12" r="3"/>
                <circle cx="4" cy="12" r="1.5" fill="currentColor"/>
                <circle cx="20" cy="12" r="1.5" fill="currentColor"/>
              </svg>
            )}
            {g.icon === 'cicd' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.5">
                <circle cx="6" cy="6" r="2.5"/>
                <circle cx="6" cy="18" r="2.5"/>
                <circle cx="18" cy="12" r="2.5"/>
                <path d="M6 8.5v7M8 7l8 3.5M8 17l8-3.5" stroke-linecap="round"/>
              </svg>
            )}
          </div>
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5 -translate-x-1 text-ink-600 transition group-hover:translate-x-0 group-hover:text-violet-400" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3.5 8h9m0 0L8.5 4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-ink-50">{g.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-ink-400">{g.desc}</p>
      </a>
    ))}
  </section>

  <!-- Features strip -->
  <section class="mt-12 grid gap-px overflow-hidden rounded-xl border border-ink-800/80 bg-ink-800/40 sm:grid-cols-3">
    {[
      { k: '11', l: 'frameworks' },
      { k: '4',  l: 'gateway types' },
      { k: '3',  l: 'CI providers' },
    ].map((s) => (
      <div class="bg-ink-950/40 p-4 text-center backdrop-blur-sm">
        <div class="text-2xl font-semibold tabular-nums text-ink-50">{s.k}</div>
        <div class="mt-0.5 text-xs uppercase tracking-wider text-ink-500">{s.l}</div>
      </div>
    ))}
  </section>
</Layout>
