---
import '../styles/global.css';
const { title = 'Stackgen' } = Astro.props;
const path = Astro.url.pathname;
const isActive = (p: string) =>
  path === p || path.startsWith(p + '/');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-30 border-b border-ink-800/60 bg-ink-950/70 backdrop-blur-md">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6">
        <a href="/" class="group flex items-center gap-2.5">
          <!-- SVG logo: hexagon stack -->
          <span class="relative inline-flex h-7 w-7 items-center justify-center rounded-md bg-violet-600/20 ring-1 ring-violet-500/40 transition group-hover:ring-violet-400/70">
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 text-violet-300" aria-hidden="true">
              <path d="M12 2.5l8.5 4.9v9.2L12 21.5l-8.5-4.9V7.4L12 2.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M12 7l4.3 2.5v5L12 17l-4.3-2.5v-5L12 7z" fill="currentColor" fill-opacity="0.35"/>
            </svg>
          </span>
          <span class="text-sm font-semibold tracking-tight text-ink-50">stackgen</span>
          <span class="hidden rounded border border-ink-800 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-ink-500 sm:inline">dev</span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          {[
            { href: '/docker', label: 'Docker' },
            { href: '/gateway', label: 'Gateway' },
            { href: '/cicd', label: 'CI/CD' },
          ].map((l) => (
            <a
              href={l.href}
              class:list={[
                'relative rounded-md px-3 py-1.5 font-medium transition',
                isActive(l.href)
                  ? 'text-violet-200 glow-violet'
                  : 'text-ink-400 hover:text-ink-100 hover:bg-ink-900/60',
              ]}
            >
              {l.label}
              {isActive(l.href) && (
                <span class="absolute -bottom-[13px] left-1/2 h-0.5 w-6 -translate-x-1/2 rounded-full bg-violet-400 shadow-[0_0_12px_rgba(167,139,250,0.9)]"></span>
              )}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8 md:px-6 md:py-12">
      <slot />
    </main>

    <footer class="mx-auto mt-8 max-w-6xl border-t border-ink-800/60 px-4 pb-10 pt-6 md:px-6">
      <div class="flex flex-col items-center justify-between gap-3 text-xs text-ink-500 sm:flex-row">
        <span>stackgen · self-hosted · generate production-ready scaffolding</span>
        <a
          href="https://github.com/denisetiya/stackgen"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-md border border-ink-800 bg-ink-900/40 px-2.5 py-1 text-ink-300 transition hover:border-ink-700 hover:bg-ink-900/70 hover:text-ink-100"
        >
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38v-1.34c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.16-.89-1.16-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.01.08-2.11 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.91.08 2.11.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.94.29.25.54.73.54 1.48v2.19c0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span class="font-mono">denisetiya/stackgen</span>
          <svg viewBox="0 0 16 16" class="h-3 w-3 text-ink-600" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 3h8v8M5 11l8-8" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </footer>
  </body>
</html>
